PORT=3000
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=60
AUTH_THROTTLE_TTL_MS=60000
AUTH_THROTTLE_LIMIT=5
JWT_SECRET=change_me_jwt_secret

# Admin credentials
ADMIN_EMAIL=admin@example.com
# Preferred for production: <salt>:<hex_hash> from scrypt
ADMIN_PASSWORD_HASH=change_me_salt:change_me_hash
# Optional fallback for local/dev only (if ADMIN_PASSWORD_HASH is empty)
ADMIN_PASSWORD=admin

# Database (Docker)
MYSQL_ROOT_USER=root
MYSQL_ROOT_PASSWORD=change_me
MYSQL_DATABASE=vodoley_db
MYSQL_USER=app
MYSQL_PASSWORD=change_me_app

# Prisma connection string (Docker)
DATABASE_URL="mysql://app:change_me_app@db:3306/vodoley_db"

# Optional cache backend
REDIS_URL=redis://redis:6379
